async def video_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not is_authorized(update):
        return
    
    duration = 5
    if context.args and context.args[0].isdigit():
        duration = min(int(context.args[0]), 30)
    
    msg = await _reply(update, f"🎥 *Recording {duration}s video...*")
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = os.path.join(PHOTO_DIR, f"video_{timestamp}.mp4")
    
    try:
        subprocess.run(
            ["termux-camera-record", "-c", "0", "-d", str(duration), filename],
            timeout=duration + 15, check=True
        )
        if os.path.exists(filename) and os.path.getsize(filename) > 5000:
            with open(filename, "rb") as f:
                await msg.delete()
                await update.effective_chat.send_video(
                    f, caption=f"🎥 *Video* | `{timestamp}` | `{duration}s`",
                    supports_streaming=True
                )
        else:
            await _edit(update, msg, "❌ Video recording failed or empty.")
    except Exception as e:
        await _edit(update, msg, f"❌ Error: `{str(e)[:100]}`")

