# --- Camera ---

async def photo_front(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not is_authorized(update):
        return
    msg = await _reply(update, "📸 *Front camera capturing...*")
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = os.path.join(PHOTO_DIR, f"front_{timestamp}.jpg")
    
    try:
        subprocess.run(["termux-camera-photo", "-c", "1", filename], timeout=15, check=True)
        if os.path.exists(filename) and os.path.getsize(filename) > 1000:
            with open(filename, "rb") as f:
                await msg.delete()
                await update.effective_chat.send_photo(
                    f, caption=f"📸 *Front Camera* | `{timestamp}`"
                )
        else:
            await _edit(update, msg, "❌ Photo empty. Check Termux camera permission.")
    except FileNotFoundError:
        await _edit(update, msg, "❌ `termux-camera-photo` not found. Install: `pkg install termux-api`")
    except subprocess.TimeoutExpired:
        await _edit(update, msg, "⏱️ Camera timeout")
    except Exception as e:
        await _edit(update, msg, f"❌ Error: `{str(e)[:100]}`")

